@model OnlineBookstore.Models.Receipt

@{
    ViewData["Title"] = "Payment Successful";
}

<section class="success-page">
    <div class="success-card">
        <div class="success-icon">✓</div>

        <h1>Payment Successful</h1>

        <p>
            Thank you for your purchase. Your payment has been processed successfully.
        </p>

        <div class="receipt-box">
            <p><strong>Amount Paid:</strong> $@Model.AmountPaid</p>
            <p><strong>Payment Date:</strong> @Model.PaymentDate</p>
        </div>

        <div class="success-actions">
            <button type="button" class="btn-secondary" onclick="">View Receipt</button>
            <a href="/" class="btn-primary">Back to Home</a>
        </div>
    </div>
</section>