@{
    ViewData["Title"] = "Payment Failed";
}

<section class="success-page">
    <div class="success-card">
        <div class="failed-icon">!</div>

        <h1>Payment Failed</h1>

        <p>
            Sorry, your payment could not be completed. Your order has been kept — please return to your cart and try again.
        </p>

        <div class="failed-actions">
            <a href="/Cart" class="btn-primary">Return to Cart</a>
            <a href="/Book" class="btn-secondary">Browse Books</a>
        </div>
    </div>
</section>