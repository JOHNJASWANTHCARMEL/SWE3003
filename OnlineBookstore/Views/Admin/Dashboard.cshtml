@model OnlineBookstore.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";

    var totalBooks = Model.Books.Count;
    var totalStock = Model.Books.Sum(book => book.Inventory.StockQuantity);
    var totalInventoryValue = Model.Books.Sum(book => book.Price * book.Inventory.StockQuantity);
}

<section class="admin-header">
    <h1>Admin Dashboard</h1>
    <p>Manage bookstore inventory and process order fulfilment.</p>
</section>

@if (TempData["FlashSuccess"] != null)
{
    <div class="flash-success">@TempData["FlashSuccess"]</div>
}

<section class="admin-stats">
    <div class="stat-card">
        <h2>@totalBooks</h2>
        <p>Total Book Titles</p>
    </div>

    <div class="stat-card">
        <h2>@totalStock</h2>
        <p>Total Stock Quantity</p>
    </div>

    <div class="stat-card">
        <h2>$@totalInventoryValue</h2>
        <p>Total Inventory Value</p>
    </div>

    <div class="stat-card">
        <h2>@Model.Orders.Count(o => o.Status == "Paid")</h2>
        <p>Orders Awaiting Fulfilment</p>
    </div>
</section>

<section class="admin-management">
    <div class="admin-form-card">
        <h2>Add Book</h2>

        <form method="post" asp-action="AddBook">
            <div class="form-group">
                <label asp-for="AddBookForm.Title">Title</label>
                <input asp-for="AddBookForm.Title" class="form-control" />
                <span asp-validation-for="AddBookForm.Title" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="AddBookForm.Author">Author</label>
                <input asp-for="AddBookForm.Author" class="form-control" />
                <span asp-validation-for="AddBookForm.Author" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="AddBookForm.Publisher">Publisher</label>
                <input asp-for="AddBookForm.Publisher" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="AddBookForm.Price">Price ($)</label>
                <input asp-for="AddBookForm.Price" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="AddBookForm.Price" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="AddBookForm.StockQuantity">Stock Quantity</label>
                <input asp-for="AddBookForm.StockQuantity" type="number" class="form-control" />
                <span asp-validation-for="AddBookForm.StockQuantity" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="AddBookForm.ImageUrl">Image URL</label>
                <input asp-for="AddBookForm.ImageUrl" class="form-control" placeholder="Paste book cover image URL" />
            </div>

            <button type="submit" class="btn-primary full-width">Add Book</button>
        </form>
    </div>

    <div class="admin-form-card">
        <h2>Remove Book</h2>

        <form method="post" asp-action="RemoveBook">
            <div class="form-group">
                <label>Select Book</label>
                <select name="id" class="form-control">
                    @foreach (var book in Model.Books)
                    {
                        <option value="@book.Id">@book.Id &mdash; @book.Specification.Title</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn-danger full-width">Remove Book</button>
        </form>

        <div class="demo-note" style="margin-top:18px;">
            <strong>Note:</strong>
            <p>Removed books are cleared from the in-memory catalogue for this session.</p>
        </div>
    </div>
</section>

<section class="report-section" id="reportTable">
    <div class="report-heading-row">
        <h2>Catalogue</h2>
        <button type="button" class="btn-dark" onclick="window.print()">Generate Report</button>
    </div>

    <table class="report-table">
        <thead>
            <tr>
                <th>Image</th>
                <th>ID</th>
                <th>Title</th>
                <th>Author</th>
                <th>Publisher</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Inventory Value</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model.Books)
            {
                <tr>
                    <td><img class="report-book-image" src="@book.ImageUrl" alt="@book.Specification.Title" /></td>
                    <td>@book.Id</td>
                    <td>@book.Specification.Title</td>
                    <td>@book.Specification.Author</td>
                    <td>@book.Specification.Publisher</td>
                    <td>$@book.Price</td>
                    <td>@book.Inventory.StockQuantity</td>
                    <td>$@(book.Price * book.Inventory.StockQuantity)</td>
                    <td><a href="/Admin/EditBook/@book.Id" class="btn-secondary" style="padding:7px 14px;font-size:13px;">Edit</a></td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="report-section">
    <div class="report-heading-row">
        <h2>Orders &amp; Fulfilment</h2>
    </div>

    @if (!Model.Orders.Any())
    {
        <p class="orders-empty">No orders have been placed yet. Orders appear here after customers complete checkout.</p>
    }
    else
    {
        <table class="report-table">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Invoice Date</th>
                    <th>Status</th>
                    <th>Shipment</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>
                            @foreach (var item in order.Items)
                            {
                                <div>@item.Book.Specification.Title &times; @item.Quantity</div>
                            }
                        </td>
                        <td>$@order.Total()</td>
                        <td>@order.Invoice.CreatedDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="order-status order-status-@order.Status.ToLower()">@order.Status</span>
                        </td>
                        <td>
                            @if (order.Shipment != null)
                            {
                                <div style="font-size:13px;">
                                    <div>@order.Shipment.Carrier</div>
                                    <div style="color:#6b7280;">@order.Shipment.TrackingNumber</div>
                                    <div style="color:#6b7280;">@order.Shipment.ShippedDate.ToString("dd MMM yyyy HH:mm")</div>
                                </div>
                            }
                            else
                            {
                                <span style="color:#9ca3af;font-size:13px;">—</span>
                            }
                        </td>
                        <td>
                            @if (order.Status == "Paid")
                            {
                                <form method="post" asp-action="ProcessFulfilment">
                                    <input type="hidden" name="orderId" value="@order.Id" />
                                    <button type="submit" class="btn-primary" style="padding:7px 14px;font-size:13px;white-space:nowrap;">
                                        Process Fulfilment
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>