@model OnlineBookstore.Models.AdminBookViewModel

@{
    ViewData["Title"] = "Edit Book";
}

<section class="page-header">
    <h1>Edit Book</h1>
    <p>Update the details for this book. Changes are reflected immediately in the catalogue.</p>
</section>

<div class="edit-book-page">
    <div class="admin-form-card">
        <form method="post" asp-action="EditBook">
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Title">Title</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Author">Author</label>
                <input asp-for="Author" class="form-control" />
                <span asp-validation-for="Author" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Publisher">Publisher</label>
                <input asp-for="Publisher" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Price">Price ($)</label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="StockQuantity">Stock Quantity</label>
                <input asp-for="StockQuantity" type="number" class="form-control" />
                <span asp-validation-for="StockQuantity" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImageUrl">Image URL</label>
                <input asp-for="ImageUrl" class="form-control" />
            </div>

            <div class="edit-book-actions">
                <button type="submit" class="btn-primary">Save Changes</button>
                <a href="/Admin/Dashboard" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
