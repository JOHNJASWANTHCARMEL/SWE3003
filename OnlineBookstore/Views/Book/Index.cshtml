@model List<OnlineBookstore.Models.Book>

<h1>Online Bookstore</h1>

<div class="book-grid">

@foreach (var book in Model)
{
    <div class="book-card">

        <h2>@book.Specification.Title</h2>

        <p>Author: @book.Specification.Author</p>

        <p>Publisher: @book.Specification.Publisher</p>

        <p>Price: $@book.Price</p>

        <p>Stock: @book.Inventory.StockQuantity</p>

        <a class="btn" href="/Cart/Add/@book.Id">
            Add To Cart
        </a>

    </div>
}

</div>